# AutoGen Asset Analyst Environment Variables
# Copy this file to .env and fill in your actual configuration

# ===========================================
# OpenAI API Configuration
# ===========================================
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com

# ===========================================
# Default Model Configuration
# ===========================================
DEFAULT_MODEL=deepseek-chat

# ===========================================
# Asset-Lens Path
# ===========================================
ASSET_LENS_PATH=../asset-lens

# ===========================================
# Knowledge Base (langchain-llm-toolkit RAG)
# ===========================================
KNOWLEDGE_BASE_PATH=../langchain-llm-toolkit

# ===========================================
# Roundtable Settings
# ===========================================
ROUNDTABLE_MAX_ROUNDS=6

# ===========================================
# Domestic Interest Rates (China)
# Update these when rates change
# ===========================================
CN_DEPOSIT_RATE=1.45
CN_LPR_RATE=3.1
CN_BOND_YIELD=1.7
